{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "Jwt": {
    "Issuer": "NutriCasa",
    "Audience": "NutriCasa.PWA",
    "Key": "",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 30
  },
  "Cors": {
    "Origins": [
      "http://localhost:4200",
      "https://localhost:4200",
      "http://localhost:8100",
      "https://nutri-casa.vercel.app"
    ]
  },
  "AllowedHosts": "*"
}